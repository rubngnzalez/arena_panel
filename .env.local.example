# ============================================
# PANEL DE GESTIÓN ARENA13 - CONFIGURACIÓN
# ============================================
# Copia este archivo a .env.local y rellena los valores
# Los valores se pueden editar desde el panel en /settings

# Supabase Configuration
# Obtén estos valores en: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=tu-proyecto-url-supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-llave-anonima-publica

# Entorno de ejecución
# Valores: local | produccion
NEXT_PUBLIC_ENVIRONMENT=local

# Dominio para producciones
# Configure los registros DNS según DNS_INSTRUCTIONS.md
NEXT_PUBLIC_DOMAIN=arenatrece.com
NEXT_PUBLIC_PANEL_SUBDOMAIN=panel

# Configuración opcional de Email
# Para habilitar notificaciones por email
EMAIL_FROM=noreply@arenatrece.com
EMAIL_REPLY_TO=info@arenatrece.com

# Integraciones (Opcional - Futuro)
KILOCODE_API_KEY=
KILOCODE_PROJECT_ID=
OPENDESIGN_API_KEY=
OPENDESIGN_TEAM_ID=
